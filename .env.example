# Copy this file to .env and replace every required placeholder.
# Never commit the resulting .env file.

ADMIN_USER=admin
ADMIN_PASS=REPLACE_WITH_A_STRONG_PASSWORD

DB_PATH=/app/data/users.db
APPARMOR_LOG_PATH=/var/log-host/kern.log
VARMOR_VIOLATION_LOG_PATH=/var/log-varmor/violations.log

ARMORPILOT_LICENSE_FILE=/app/data/license.json
ARMORPILOT_LICENSE_REQUIRED=true
ARMORPILOT_LICENSE_FAIL_OPEN=false
ARMORPILOT_LICENSE_ALLOW_ENV_PUBLIC_KEY=false
ARMORPILOT_LICENSE_ALLOW_HS256=false
ARMORPILOT_LICENSE_REQUIRE_INSTALLATION_BINDING=true
ARMORPILOT_INSTALLATION_KEY_FILE=/app/data/installation-private.pem
ARMORPILOT_INSTALLATION_METADATA_FILE=/app/data/installation.json
ARMORPILOT_TRIAL_DAYS=30
