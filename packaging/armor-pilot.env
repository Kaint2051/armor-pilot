# ArmorPilot configuration
# Edit this file before starting the service for the first time.

# Listening address and port
HOST=0.0.0.0
PORT=5000

# Persistent data directory
DB_PATH=/var/lib/armor-pilot/users.db
ARMORPILOT_LICENSE_FILE=/var/lib/armor-pilot/license.json

# Initial admin credentials — REQUIRED on first startup (when no users exist).
# After the first user is seeded these values are ignored.
# Use a strong password (min 12 characters).
ADMIN_USER=admin
ADMIN_PASS=

# Kubernetes config — leave empty to use the in-cluster service account or
# the default kubeconfig at ~/.kube/config.
# KUBECONFIG=/home/ubuntu/.kube/config
